<div class="admin-opties">
  <h1>Antwoordopties</h1>
  <h2><%= vraag.vraag_tekst %></h2>

  <% if (opties.length > 0) { %>
    <h3>Huidige opties</h3>
    <div class="opties-lijst">
      <% opties.forEach(o => { %>
        <div class="optie-item <%= o.is_correct ? 'optie-correct' : '' %>">
          <span class="optie-label-big"><%= o.label %></span>
          <span class="optie-tekst"><%= o.tekst %></span>
          <% if (o.is_correct) { %>
            <span class="correct-badge">✓ Correct</span>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } %>

  <div class="nieuw-opties-form">
    <h3>Opties toevoegen</h3>
    <form action="/admin/opties/toevoegen" method="POST">
      <input type="hidden" name="vraag_id" value="<%= vraag.id %>">
      <input type="hidden" name="examen_id" value="<%= examen.id %>">

      <div id="opties-container">
        <div class="optie-row">
          <div class="form-group">
            <label>Label</label>
            <input type="text" name="labels" value="A" required style="width:60px; text-align:center; font-weight:bold;">
          </div>
          <div class="form-group" style="flex:1">
            <label>Tekst</label>
            <input type="text" name="teksten" placeholder="Antwoordtekst..." required>
          </div>
          <div class="form-group checkbox-group">
            <label>
              <input type="checkbox" name="correct" value="0">
              Correct antwoord
            </label>
          </div>
        </div>

        <div class="optie-row">
          <div class="form-group">
            <input type="text" name="labels" value="B" required style="width:60px; text-align:center; font-weight:bold;">
          </div>
          <div class="form-group" style="flex:1">
            <input type="text" name="teksten" placeholder="Antwoordtekst..." required>
          </div>
          <div class="form-group checkbox-group">
            <label>
              <input type="checkbox" name="correct" value="1">
              Correct antwoord
            </label>
          </div>
        </div>

        <div class="optie-row">
          <div class="form-group">
            <input type="text" name="labels" value="C" required style="width:60px; text-align:center; font-weight:bold;">
          </div>
          <div class="form-group" style="flex:1">
            <input type="text" name="teksten" placeholder="Antwoordtekst..." required>
          </div>
          <div class="form-group checkbox-group">
            <label>
              <input type="checkbox" name="correct" value="2">
              Correct antwoord
            </label>
          </div>
        </div>

        <div class="optie-row">
          <div class="form-group">
            <input type="text" name="labels" value="D" required style="width:60px; text-align:center; font-weight:bold;">
          </div>
          <div class="form-group" style="flex:1">
            <input type="text" name="teksten" placeholder="Antwoordtekst..." required>
          </div>
          <div class="form-group checkbox-group">
            <label>
              <input type="checkbox" name="correct" value="3">
              Correct antwoord
            </label>
          </div>
        </div>
      </div>

      <button type="submit" class="btn-primary">Opties Opslaan</button>
      <a href="/admin/vragen/<%= examen.id %>" class="btn-secondary">← Terug</a>
    </form>
  </div>
</div>

<style>
.opties-lijst {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 24px;
}
.optie-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  background: var(--bg);
  border-radius: var(--radius);
  border: 2px solid var(--border);
}
.optie-item.optie-correct {
  background: #f0fff4;
  border-color: var(--success);
}
.optie-label-big {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary);
  color: white;
  border-radius: 50%;
  font-weight: 700;
}
.correct-badge {
  margin-left: auto;
  background: var(--success);
  color: white;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 0.75rem;
  font-weight: 600;
}
.nieuw-opties-form {
  background: white;
  border-radius: var(--radius-lg);
  padding: 24px;
  box-shadow: var(--shadow);
}
.optie-row {
  display: flex;
  align-items: flex-end;
  gap: 12px;
  margin-bottom: 12px;
}
</style>
