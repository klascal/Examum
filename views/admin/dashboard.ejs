<div class="admin-dashboard">
  <h1>Beheerdersdashboard</h1>

  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-label">Examens</div>
      <div class="stat-number"><%= stats.examens %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Kandidaten</div>
      <div class="stat-number"><%= stats.kandidaten %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Docenten</div>
      <div class="stat-number"><%= stats.docenten %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Actief</div>
      <div class="stat-number"><%= stats.actief %></div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Afgerond</div>
      <div class="stat-number"><%= stats.afgerond %></div>
    </div>
  </div>

  <div class="admin-nav">
    <a href="/admin/kandidaten" class="btn-nav"><span class="icon">group</span> Kandidaten</a>
    <a href="/admin/docenten" class="btn-nav"><span class="icon">supervisor_account</span> Docenten</a>
    <a href="/admin/examens" class="btn-nav"><span class="icon">book_2</span> Examens</a>
    <a href="/docent" class="btn-nav"><span class="icon">fact_check</span> Nakijken</a>
  </div>

  <h2>Recente Resultaten</h2>
  <table class="data-table">
    <thead>
      <tr>
        <th>Kandidaat</th>
        <th>Examen</th>
        <th>Score</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% recenteResultaten.forEach(r => { %>
        <tr>
          <td><%= r.kandidaat_naam %></td>
          <td><%= r.examen_titel %></td>
          <td><%= r.score_percentage %>%</td>
          <td>
            <span class="badge <%= r.geslaagd ? 'badge-success' : 'badge-danger' %>">
              <%= r.geslaagd ? 'Geslaagd' : 'Gezakt' %>
            </span>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
